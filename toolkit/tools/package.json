{
    "name":  "@acki/toolkit",
    "version":  "0.1.0",
    "description":  "ACKI Development Toolkit",
    "private":  true,
    "type":  "module",
    "main":  "dist/index.js",
    "bin":  {
                "acki":  "dist/index.js"
            },
    "scripts":  {
                    "build":  "tsc",
                    "dev":  "tsx src/index.ts",
                    "start":  "node dist/index.js",
                    "lint":  "eslint src",
                    "test":  "vitest run"
                },
    "dependencies":  {
                         "chalk":  "^5.3.0",
                         "commander":  "^12.1.0"
                     },
    "devDependencies":  {
                            "@eslint/js":  "^10.0.1",
                            "@types/node":  "^22.10.2",
                            "eslint":  "^10.6.0",
                            "globals":  "^17.7.0",
                            "tsx":  "^4.19.2",
                            "typescript":  "^5.7.2",
                            "typescript-eslint":  "^8.63.0",
                            "vitest":  "^4.1.10"
                        }
}
